# AI/ML API Configuration
AIML_API_KEY=your_aiml_api_key_here
AIML_API_BASE=https://api.aimlapi.com/v1

# Band (Thenvoi) Platform - each agent needs its own ID + API key
# Create agents at https://app.band.ai/agents
BAND_INTAKE_AGENT_ID=your_intake_agent_uuid
BAND_INTAKE_API_KEY=your_intake_agent_api_key
BAND_DIAGNOSTIC_AGENT_ID=your_diagnostic_agent_uuid
BAND_DIAGNOSTIC_API_KEY=your_diagnostic_agent_api_key
BAND_REVIEWER_AGENT_ID=your_reviewer_agent_uuid
BAND_REVIEWER_API_KEY=your_reviewer_agent_api_key
BAND_LIAISON_AGENT_ID=your_liaison_agent_uuid
BAND_LIAISON_API_KEY=your_liaison_agent_api_key
BAND_SOLUTION_AGENT_ID=your_solution_agent_uuid
BAND_SOLUTION_API_KEY=your_solution_agent_api_key
BAND_PHARMACY_AGENT_ID=your_pharmacy_agent_uuid
BAND_PHARMACY_API_KEY=your_pharmacy_agent_api_key

# OpenAI API key (for LangGraph adapter in Band SDK)
OPENAI_API_KEY=your_openai_api_key_here

# Doctor simulation
SIMULATE_DOCTOR_RESPONSE=true
DOCTOR_RESPONSE_DELAY_SECONDS=10

# Optional RAG (future)
ENABLE_RAG=false
KNOWLEDGE_BASE_PATH=./knowledge_base
